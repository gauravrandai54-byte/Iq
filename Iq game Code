const goFinalIq=document.getElementById('go-final-iq'),goProfile=document.getElementById('go-profile'),goSub=document.getElementById('go-sub');
const btnStart=document.getElementById('btn-start'),btnLb=document.getElementById('btn-lb'),btnSettingsMenu=document.getElementById('btn-settings-menu'),btnBack=document.getElementById('btn-back'),btnSettingsGame=document.getElementById('btn-settings-game'),btnLbBack=document.getElementById('btn-lb-back'),btnSettingsBack=document.getElementById('btn-settings-back'),btnClearHistory=document.getElementById('btn-clear-history'),btnLuContinue=document.getElementById('btn-lu-continue'),btnGoPlayAgain=document.getElementById('btn-go-playagain'),btnGoMenu=document.getElementById('btn-go-menu'),btnConfirmYes=document.getElementById('btn-confirm-yes'),btnConfirmNo=document.getElementById('btn-confirm-no');
const MASTER_SYMBOLS=['★','■','●','▲','◆'];
let iqScore=85,currentRound=1,currentSequence=[],correctAnswerIndex=0,canGuess=!0,gameActive=!0,streakCount=0,recentResults=[null,null,null],audioCtx=null,soundEnabled=!0,vibeEnabled=!0,lastAnnouncedLevel=85;
const IQ_LEVELS=[{threshold:90,title:'Good Start!',msg:'Your brain is waking up!'},{threshold:100,title:'Nice!',msg:'You reached average score!'},{threshold:115,title:'Smart!',msg:'You are above average!'},{threshold:130,title:'Very Smart!',msg:'Top 2% of people!'},{threshold:145,title:'Genius!',msg:'Amazing brain power!'},{threshold:160,title:'Perfect!',msg:'Almost maximum score!'}];
const LEADERBOARD=[{name:'Alex Turing',score:162},{name:'Marie Curie',score:158},{name:'Leo da Vinci',score:155},{name:'Kim Johnson',score:152},{name:'Sam Raman',score:150},{name:'Helen Hypatia',score:148},{name:'Nikola Tesla',score:145},{name:'Rose Franklin',score:142},{name:'Charles Darwin',score:140},{name:'Grace Hopper',score:138}];
const QUOTES=['🧠 Your brain is capable of amazing things','💪 Every challenge makes you stronger','🎯 Focus. Pattern. Succeed.','⭐ Small steps every day lead to big results','🔥 Your potential is limitless','✨ Believe in your abilities','🌟 You are smarter than you think','⚡ Train your brain. Unlock your power.','🎮 Play. Learn. Grow.','🏆 Consistency beats talent every time'];
let quoteIndex=Math.floor(Math.random()*QUOTES.length);
motivationQuote.textContent=QUOTES[quoteIndex];
motivationQuote.style.transition='opacity 0.2s ease';
setInterval(()=>{let n;do{n=Math.floor(Math.random()*QUOTES.length)}while(n===quoteIndex&&QUOTES.length>1);quoteIndex=n;motivationQuote.style.opacity='0';setTimeout(()=>{motivationQuote.textContent=QUOTES[quoteIndex];motivationQuote.style.opacity='1'},200)},5000);
function switchScreen(e){Object.values(screens).forEach(e=>e.classList.remove('active'));screens[e].classList.add('active')}
function openOverlay(e){e.classList.add('open')}
function closeOverlay(e){e.classList.remove('open')}
function vibrate(e){vibeEnabled&&navigator.vibrate&&navigator.vibrate(e)}
function initAudio(){if(!audioCtx)try{audioCtx=new (window.AudioContext||window.webkitAudioContext)()}catch(e){console.warn('Web Audio not supported')}}
function resumeAudio(){audioCtx&&'suspended'===audioCtx.state&&audioCtx.resume()}
function playSound(e){if(!soundEnabled||!audioCtx)return;resumeAudio();let t=audioCtx.currentTime,o=audioCtx.createOscillator(),n=audioCtx.createGain();if(o.connect(n),n.connect(audioCtx.destination),'tap'===e)o.frequency.value=440,n.gain.setValueAtTime(.1,t),n.gain.exponentialRampToValueAtTime(.001,t+.05),o.start(),o.stop(t+.05);else if('correct'===e)o.frequency.value=523.25,n.gain.setValueAtTime(.08,t),n.gain.exponentialRampToValueAtTime(.001,t+.1),o.start(),o.frequency.setValueAtTime(659.25,t+.06),o.stop(t+.12);else if('wrong'===e)o.frequency.value=110,n.gain.setValueAtTime(.15,t),n.gain.exponentialRampToValueAtTime(.001,t+.2),o.start(),o.stop(t+.2);else if('levelup'===e)[523.25,659.25,783.99,1046.5].forEach((e,i)=>{let l=audioCtx.createOscillator(),a=audioCtx.createGain();l.connect(a),a.connect(audioCtx.destination),l.frequency.value=e,a.gain.setValueAtTime(.06,t+.08*i),a.gain.exponentialRampToValueAtTime(.001,t+.08*i+.15),l.start(t+.08*i),l.stop(t+.08*i+.15)})}function saveScoreToHistory(e,t){let o=JSON.parse(localStorage.getItem('iqHistory')||'[]'),n=new Date,i=`${n.getMonth()+1}/${n.getDate()}`;o.unshift({date:i,score:e,round:t}),o.length>10&&o.pop(),localStorage.setItem('iqHistory',JSON.stringify(o)),localStorage.setItem('lastIq',e),updateMenuHistory()}
function updateMenuHistory(){let e=JSON.parse(localStorage.getItem('iqHistory')||'[]'),t=localStorage.getItem('lastIq');t?lastScoreVal.textContent=`🧠 ${t} IQ`:lastScoreVal.textContent='---';0===e.length?historyMini.innerHTML='<span class="no-history">No sessions yet</span>':historyMini.innerHTML=e.slice(0,5).map(e=>`<span class="hchip">${e.date} <span>${e.score}</span></span>`).join('')}
function getBestScore(){let e=JSON.parse(localStorage.getItem('iqHistory')||'[]');return 0===e.length?0:Math.max(...e.map(e=>e.score))}
function renderLeaderboard(){lbList.innerHTML=LEADERBOARD.map((e,t)=>`<div class="lb-row"><span class="lb-rank">${t+1}</span><span class="lb-name">${e.name}</span><span class="lb-score">${e.score}</span></div>`).join('');let e=getBestScore();if(e>0){let t=LEADERBOARD.findIndex(t=>t.score<e)+1;0===t&&(t=LEADERBOARD.length+1);lbYouPos.textContent=`Your Best: ${e} IQ • Rank #${t}`}else lbYouPos.textContent='Your Best: -- • Complete a test!'}
function updateResultDots(e){recentResults.push(e),recentResults.shift(),recentResults.forEach((e,t)=>{!0===e?(dots[t].innerHTML='✓',dots[t].style.background='rgba(76,175,80,0.3)',dots[t].style.color='#4CAF50'):!1===e?(dots[t].innerHTML='✗',dots[t].style.background='rgba(255,90,90,0.3)',dots[t].style.color='#FF5A5A'):(dots[t].innerHTML='—',dots[t].style.background='rgba(255,255,255,0.1)',dots[t].style.color='rgba(255,255,255,0.4)')})}
function updateIqDisplay(e=!0){iqNum.textContent=iqScore;e&&(iqNum.classList.add('pop'),setTimeout(()=>iqNum.classList.remove('pop'),200))}
function checkLevelUp(){for(let e of IQ_LEVELS)if(iqScore>=e.threshold&&lastAnnouncedLevel<e.threshold)return lastAnnouncedLevel=e.threshold,luTitle.textContent=e.title,luMsg.textContent=e.msg,luScoreVal.textContent=iqScore,openOverlay(overlays.levelup),playSound('levelup'),vibrate(100),!0;return!1}
function generateSequence(e){let t=[];for(let o=0;o<e;o++)t.push(MASTER_SYMBOLS[Math.floor(Math.random()*MASTER_SYMBOLS.length)]);return t}
function applyRule(e,t){let o=[...e];if('rotate'===t){let e=o.pop();o.unshift(e)}else if('increment'===t)for(let e=0;e<o.length;e++){let t=MASTER_SYMBOLS.indexOf(o[e]);o[e]=MASTER_SYMBOLS[(t+1)%MASTER_SYMBOLS.length]}else'rotate'!==t&&'increment'!==t||o.reverse();return o}
function shuffleArray(e){for(let t=e.length-1;t>0;t--){let o=Math.floor(Math.random()*(t+1));[e[t],e[o]]=[e[o],e[t]]}return e}
function generateNewRound(){let e=Math.min(3+Math.floor(currentRound/3),7);currentSequence=generateSequence(e);let t=['rotate','increment','mirror'],o=t[Math.floor(Math.random()*t.length)],n=applyRule(currentSequence,o),i,l;do{i=shuffleArray([...n])}while(JSON.stringify(i)===JSON.stringify(n));do{l=shuffleArray([...n])}while(JSON.stringify(l)===JSON.stringify(n)||JSON.stringify(l)===JSON.stringify(i));let a=[n,i,l],r=shuffleArray([...a]);correctAnswerIndex=r.findIndex(e=>JSON.stringify(e)===JSON.stringify(n));promptSeq.textContent=currentSequence.join(' ');roundNum.textContent=currentRound;choicesDiv.innerHTML='';r.forEach((e,t)=>{let o=document.createElement('button');o.className='cbtn';o.textContent=e.join(' ');o.addEventListener('click',()=>handleChoice(t));choicesDiv.appendChild(o)});canGuess=!0;streakTag.classList.remove('show')}
function handleChoice(e){if(!gameActive||!canGuess)return;canGuess=!1;let t=document.querySelectorAll('.cbtn');t.forEach(e=>e.disabled=!0);playSound('tap');vibrate(10);let o=e===correctAnswerIndex;if(o){t[e].classList.add('flash-ok');let n=3;streakCount++,streakCount>=3?(n+=5,streakTag.classList.add('show'),streakCount=0,playSound('correct'),vibrate(50)):(playSound('correct'),vibrate(10));iqScore=Math.min(165,iqScore+n);updateIqDisplay(!0);updateResultDots(!0);feedbackTxt.textContent=`+${n} IQ!`;feedbackTxt.className='show ok';currentRound++;setTimeout(()=>{feedbackTxt.classList.remove('show');t.forEach(e=>e.classList.remove('flash-ok'));let n=checkLevelUp(),i=()=>{gameActive&&generateNewRound()};if(n){let e=()=>{closeOverlay(overlays.levelup),i(),btnLuContinue.removeEventListener('click',e)};btnLuContinue.addEventListener('click',e)}else i()},600)}else{t[e].classList.add('flash-bad');t[correctAnswerIndex].classList.add('flash-ok');playSound('wrong');vibrate([50,30,50]);updateResultDots(!1);feedbackTxt.textContent='Wrong! Game Over';feedbackTxt.className='show bad';gameActive=!1;setTimeout(()=>{feedbackTxt.classList.remove('show');saveScoreToHistory(iqScore,currentRound);goFinalIq.textContent=iqScore;goSub.textContent=`You reached Round ${currentRound}`;iqScore<100?goProfile.textContent='Analytical Observer':iqScore<115?goProfile.textContent='Pattern Savant':iqScore<130?goProfile.textContent='Cognitive Elite':iqScore<145?goProfile.textContent='Master Thinker':goProfile.textContent='Genius Level';openOverlay(overlays.gameover);t.forEach(e=>{e.classList.remove('flash-ok','flash-bad'),e.disabled=!1})},600)}}
function resetGame(){iqScore=85;currentRound=1;streakCount=0;gameActive=!0;canGuess=!0;recentResults=[null,null,null];lastAnnouncedLevel=85;updateIqDisplay(!1);updateResultDots(null);generateNewRound();streakTag.classList.remove('show');feedbackTxt.classList.remove('show')}
window.addEventListener('load',()=>{let e=document.getElementById('load-bar'),t=document.getElementById('load-dots'),o=0,n=setInterval(()=>{o=(o+1)%4,t.textContent='.'.repeat(o)},400);setTimeout(()=>{e.style.width='100%'},50);setTimeout(()=>{clearInterval(n),screens.loading.classList.remove('active'),screens.menu.classList.add('active'),updateMenuHistory()},3000)});
btnStart.addEventListener('click',()=>{initAudio(),resumeAudio(),resetGame(),switchScreen('game'),vibrate(10)});
btnLb.addEventListener('click',()=>{renderLeaderboard(),openOverlay(overlays.lb),vibrate(10)});
btnSettingsMenu.addEventListener('click',()=>{openOverlay(overlays.settings),vibrate(10)});
btnSettingsGame.addEventListener('click',()=>{openOverlay(overlays.settings),vibrate(10)});
btnBack.addEventListener('click',()=>{gameActive?openOverlay(overlays.confirm):(switchScreen('menu'),updateMenuHistory());vibrate(10)});
btnConfirmYes.addEventListener('click',()=>{closeOverlay(overlays.confirm),gameActive=!1,switchScreen('menu'),updateMenuHistory(),vibrate(10)});
btnConfirmNo.addEventListener('click',()=>{closeOverlay(overlays.confirm),vibrate(10)});
btnLbBack.addEventListener('click',()=>{closeOverlay(overlays.lb),vibrate(10)});
btnSettingsBack.addEventListener('click',()=>{closeOverlay(overlays.settings),vibrate(10)});
btnClearHistory.addEventListener('click',e=>{e.stopPropagation(),localStorage.removeItem('iqHistory'),localStorage.removeItem('lastIq'),updateMenuHistory(),closeOverlay(overlays.settings),playSound('tap'),vibrate(50)});
btnGoPlayAgain.addEventListener('click',()=>{closeOverlay(overlays.gameover),resetGame(),vibrate(10)});
btnGoMenu.addEventListener('click',()=>{closeOverlay(overlays.gameover),switchScreen('menu'),updateMenuHistory(),vibrate(10)});
toggleSound.addEventListener('change',e=>{soundEnabled=e.target.checked,localStorage.setItem('soundEnabled',soundEnabled),soundEnabled&&initAudio(),vibrate(5)});
toggleVibe.addEventListener('change',e=>{vibeEnabled=e.target.checked,localStorage.setItem('vibeEnabled',vibeEnabled),vibrate(5)});
!function(){let e=localStorage.getItem('soundEnabled');null!==e&&(soundEnabled='true'===e,toggleSound.checked=soundEnabled);let t=localStorage.getItem('vibeEnabled');null!==t&&(vibeEnabled='true'===t,toggleVibe.checked=vibeEnabled)}();
document.body.addEventListener('click',()=>{audioCtx&&'suspended'===audioCtx.state&&audioCtx.resume()},{once:!0});
})();
</script>
